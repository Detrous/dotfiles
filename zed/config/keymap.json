[
  // Tasks
  {
    "context": "Editor",
      "bindings": {
        "ctrl-t f": ["task::Spawn", { "task_name": "test: $ZED_STEM" }]
      }
  },
  {
    "context": "Editor",
      "bindings": {
        "ctrl-t d": ["task::Spawn", { "task_name": "test: $ZED_RELATIVE_DIR" }]
      }
  },
  // Keymaps
  {
    "context": "Terminal",
    "bindings": {
      "shift-enter": [
        "terminal::SendText",
        "\u001b\r"
      ]
    }
  },
  {
    "bindings": {
      "ctrl-v space": "terminal_panel::ToggleFocus"
    }
  },
  {
    "bindings": {
      "cmd-shift-k": "workspace::ActivatePaneUp"
    }
  },
  {
    "context": "Terminal",
    "bindings": {
      "shift-up": null
    }
  },
  {
    "context": "Terminal",
    "bindings": {
      "shift-down": null
    }
  }
]
